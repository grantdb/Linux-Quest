{
    "name":  "linux-quest",
    "version":  "0.0.14",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "devvit playtest",
                    "bundle":  "cd webviews \u0026\u0026 npm run build",
                    "build":  "node --experimental-strip-types ./tools/build.ts --minify",
                    "watch":  "node --experimental-strip-types ./tools/build.ts",
                    "upload":  "npm run bundle \u0026\u0026 npm run build \u0026\u0026 node ../../scripts/validate-build.js \u0026\u0026 devvit upload",
                    "publish:public":  "npm run bundle \u0026\u0026 npm run build \u0026\u0026 node ../../scripts/validate-build.js \u0026\u0026 devvit publish --public",
                    "type-check":  "tsc --noEmit"
                },
    "dependencies":  {
                         "@devvit/public-api":  "0.12.21"
                     },
    "devDependencies":  {
                            "devvit":  "0.12.21",
                            "typescript":  "latest"
                        }
}
